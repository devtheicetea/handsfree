{
  "name": "handsfree-bridge",
  "version": "0.1.6",
  "description": "Self-hosted backend for the Handsfree iOS app — talk to Claude Code or Codex hands-free from your phone.",
  "type": "module",
  "license": "MIT",
  "author": "Contrast Studio LLC",
  "homepage": "https://github.com/devtheicetea/handsfree#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devtheicetea/handsfree.git"
  },
  "bugs": {
    "url": "https://github.com/devtheicetea/handsfree/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "coding-agent",
    "voice",
    "handsfree",
    "websocket",
    "bridge"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "handsfree-bridge": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --experimental-strip-types src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pair": "node dist/pairing-cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@openai/codex": "^0.139.0",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
